# Шаблон настроек бэкенда. Скопируйте в backend/.env и заполните.
#   cp backend/.env.example backend/.env
# Файл .env НЕ коммитится (в нём пароли и токены).

# --- База данных ---
# В Docker DB_HOST = имя сервиса из docker-compose (db).
# Без Docker — localhost или адрес вашего PostgreSQL.
DB_HOST=db
DB_PORT=5432
DB_USER=bpm
DB_PASS=ПРИДУМАЙТЕ_СЛОЖНЫЙ_ПАРОЛЬ
DB_NAME=bpm

# --- Безопасность ---
# ОБЯЗАТЕЛЬНО замените на свою длинную случайную строку (32+ символов).
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ
JWT_TTL_HOURS=12

# Режим входа: dev (без пароля, только для теста) | oidc (Keycloak, продакшен)
AUTH_MODE=dev

# Публичный адрес приложения — для ссылок в письмах/Telegram
APP_BASE_URL=https://bpm.вашдомен.kz
# Разрешённые источники для CORS (обычно тот же домен)
CORS_ORIGINS=["https://bpm.вашдомен.kz"]

# --- Уведомления по e-mail (необязательно) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Приём ответов согласования по почте (необязательно, включает кнопки) ---
IMAP_HOST=
IMAP_PORT=993

# --- Telegram-бот (необязательно) ---
TELEGRAM_BOT_TOKEN=

# --- Хранилище файлов ---
# local — на диске контейнера (том backend_storage); s3 — S3-совместимое.
# Тонкие настройки правятся в UI («Настройки BPM»), здесь — значения по умолчанию.
STORAGE_BACKEND=local
MAX_UPLOAD_MB=50
